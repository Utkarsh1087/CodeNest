# Server Configuration
PORT=3000

# Persistence Layer (MongoDB Atlas)
# Replace with your connection string from MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/rooms

# AI Copilot Engine (Google Gemini)
# Obtain your key from https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
